DATABASE_URL="postgresql://postgres:postgres@localhost:5432/deliver?schema=public"

# Optional: Prisma CLI can use a separate Prisma Postgres URL while the app uses DATABASE_URL.
PRISMA_DATABASE_URL=""

# Development OTP mode does not send SMS/WhatsApp/Telegram.
OTP_PROVIDER="dev"

# Geo provider. Use "dev" without external keys, or "2gis" with real 2GIS keys.
GEO_PROVIDER="dev"
TWOGIS_API_KEY=""
NEXT_PUBLIC_TWOGIS_MAP_KEY=""

# Required for Vercel Cron and /api/jobs/* endpoints.
CRON_SECRET=""
